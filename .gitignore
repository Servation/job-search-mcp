# --- Dependencies ---
node_modules/
.npm/
.pnpm-store/

# --- Build output (regenerated by `npm run build`; shipped via package.json "files") ---
dist/
*.tsbuildinfo

# --- Local data (per-user job store; contains your resume/profile + saved jobs) ---
data/
jobs.json
*.json.tmp

# --- Secrets / environment ---
.env
.env.*
!.env.example

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/

# --- Packing / publish artifacts ---
*.tgz

# --- MCP Registry publisher CLI (downloaded binary, not part of the package) ---
mcp-publisher.exe
mcp-publisher*.tar.gz

# --- Scratch / temp test scripts (used during development, not committed) ---
_*.mjs
_*.js
*.tmp

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
